rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Core Primitives
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'rinomasstbi@gmail.com';
    }

    function isApproved() {
      return isAdmin() || exists(/databases/$(database)/documents/approved_users/$(request.auth.token.email));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Blueprint Validation Helpers
    function isValidTP(data) {
      return data.keys().hasAll(['userId', 'subject', 'creatorEmail', 'creatorName', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.subject is string && data.subject.size() <= 200
        && data.creatorEmail == request.auth.token.email
        && data.creatorName is string && data.creatorName.size() <= 200
        && (!('grade' in data) || (data.grade is string && data.grade.size() <= 100))
        && (!('cpSourceVersion' in data) || (data.cpSourceVersion is string && data.cpSourceVersion.size() <= 200))
        && (!('additionalNotes' in data) || (data.additionalNotes is string && data.additionalNotes.size() <= 10000))
        && (!('cpElements' in data) || data.cpElements is list)
        && (!('tpGroups' in data) || data.tpGroups is list)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidATP(data) {
      return data.keys().hasAll(['userId', 'tpId', 'subject', 'creatorName', 'creatorEmail', 'createdAt'])
        && data.userId == request.auth.uid
        && data.tpId is string && data.tpId.size() <= 128
        && data.subject is string && data.subject.size() <= 200
        && data.creatorEmail == request.auth.token.email
        && data.creatorName is string && data.creatorName.size() <= 200
        && (!('content' in data) || data.content is list)
        && data.createdAt is timestamp;
    }

    function isValidPROTA(data) {
      return data.keys().hasAll(['userId', 'tpId', 'subject', 'createdAt'])
        && data.userId == request.auth.uid
        && data.tpId is string && data.tpId.size() <= 128
        && data.subject is string && data.subject.size() <= 200
        && (!('jamPertemuan' in data) || data.jamPertemuan is number)
        && (!('content' in data) || data.content is list)
        && (!('creatorName' in data) || (data.creatorName is string && data.creatorName.size() <= 200))
        && data.createdAt is timestamp;
    }

    function isValidKKTP(data) {
      return data.keys().hasAll(['userId', 'atpId', 'subject', 'semester', 'createdAt'])
        && data.userId == request.auth.uid
        && data.atpId is string && data.atpId.size() <= 128
        && data.subject is string && data.subject.size() <= 200
        && (!('grade' in data) || (data.grade is string && data.grade.size() <= 100))
        && data.semester is string && data.semester.size() <= 50
        && (!('content' in data) || data.content is list)
        && data.createdAt is timestamp;
    }

    function isValidPROSEM(data) {
      return data.keys().hasAll(['userId', 'protaId', 'subject', 'semester', 'createdAt'])
        && data.userId == request.auth.uid
        && data.protaId is string && data.protaId.size() <= 128
        && data.subject is string && data.subject.size() <= 200
        && (!('grade' in data) || (data.grade is string && data.grade.size() <= 100))
        && data.semester is string && data.semester.size() <= 50
        && (!('headers' in data) || data.headers is list)
        && (!('content' in data) || data.content is list)
        && data.createdAt is timestamp;
    }

    // 3. Security Rules
    match /approved_users/{email} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    match /tps/{tpId} {
      allow get: if isValidId(tpId);
      allow list: if true;
      allow create: if isApproved() 
                    && isValidId(tpId) 
                    && isValidTP(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isApproved() 
                    && isValidId(tpId) 
                    && existing().userId == request.auth.uid
                    && isValidTP(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      allow delete: if isApproved() && isValidId(tpId) && existing().userId == request.auth.uid;
    }

    match /atps/{atpId} {
      allow get: if isValidId(atpId);
      allow list: if true;
      allow create: if isApproved() 
                    && isValidId(atpId) 
                    && isValidATP(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isApproved() 
                    && isValidId(atpId) 
                    && existing().userId == request.auth.uid
                    && isValidATP(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() && isValidId(atpId) && existing().userId == request.auth.uid;
    }

    match /protas/{protaId} {
      allow get: if isValidId(protaId);
      allow list: if true;
      allow create: if isApproved() 
                    && isValidId(protaId) 
                    && isValidPROTA(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isApproved() 
                    && isValidId(protaId) 
                    && existing().userId == request.auth.uid
                    && isValidPROTA(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() && isValidId(protaId) && existing().userId == request.auth.uid;
    }

    match /kktps/{kktpId} {
      allow get: if isValidId(kktpId);
      allow list: if true;
      allow create: if isApproved() 
                    && isValidId(kktpId) 
                    && isValidKKTP(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isApproved() 
                    && isValidId(kktpId) 
                    && existing().userId == request.auth.uid
                    && isValidKKTP(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() && isValidId(kktpId) && existing().userId == request.auth.uid;
    }

    match /prosems/{prosemId} {
      allow get: if isValidId(prosemId);
      allow list: if true;
      allow create: if isApproved() 
                    && isValidId(prosemId) 
                    && isValidPROSEM(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isApproved() 
                    && isValidId(prosemId) 
                    && existing().userId == request.auth.uid
                    && isValidPROSEM(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isApproved() && isValidId(prosemId) && existing().userId == request.auth.uid;
    }
  }
}
